<?xml version="1.0" encoding="UTF-8"?>
<!-- Quiet logging for the interactive demo targets: prompts and answers are the UI, so only
     warnings and errors may interleave with them. -->
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
