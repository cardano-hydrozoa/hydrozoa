<configuration>

    <root level="error">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{64}) %n%msg%n
            </pattern>
        </encoder>
    </appender>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>integration-tests.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{64} %n%msg%n
            </pattern>
        </encoder>
    </appender>

    <appender name="MERMAID" class="ch.qos.logback.core.FileAppender">
        <file>stage4-peers-interaction.mmd</file>
        <append>false</append>
        <layout class="hydrozoa.integration.MermaidSequenceDiagramLayout">
            <pattern>%msg%n</pattern>
        </layout>
    </appender>
    <logger name="Mermaid.PeerLiaison" level="info" additivity="false">
        <appender-ref ref="MERMAID"/>
    </logger>


    <!-- default: warn -->
    <logger name="org.scalacheck.commands.ModelBasedSuite" level="warn"/>
    <logger name="test.CardanoBackendMock" level="warn"/>

    <!-- default: info -->
    <logger name="Stage1.Commands" level="info"/>
    <logger name="Stage1.CommandGenerators" level="info"/>
    <logger name="Stage1.ScenarioGenerators" level="info"/>
    <logger name="Stage1.Model" level="info"/>
    <logger name="Stage1.Sut" level="info"/>
    <logger name="Stage1.Suite" level="info"/>

    <!-- default: info -->
    <logger name="Stage4.Commands" level="info"/>
    <logger name="Stage4.CommandGenerators" level="info"/>
    <logger name="Stage4.ScenarioGenerators" level="info"/>
    <logger name="Stage4.Model" level="info"/>
    <logger name="Stage4.Sut" level="info"/>
    <logger name="Stage4.Suite" level="info"/>

    <!-- default: warn -->
    <logger name="BlockWeaver" level="warn"/>
    <logger name="ConsensusActor" level="warn"/>
    <logger name="EventSequencer" level="warn"/>
    <logger name="CardanoLiaison" level="warn"/>
    <logger name="JointLedger" level="warn"/>
    <logger name="PeerLiaison" level="warn"/>
    <logger name="PeerLiaisonMermaid" level="warn"/>
    <logger name="TxTiming" level="warn"/>
    <logger name="DepositsMap" level="warn"/>

    <!-- default: warn -->
    <logger name="scalus" level="warn"/>
</configuration>
