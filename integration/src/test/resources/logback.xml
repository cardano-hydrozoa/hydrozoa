<configuration>

    <root level="debug">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- IMPORTANT

         Timestamps added by the logging framework
         by `%d{HH:mm:ss.SSS}` in <pattern>
         when using mock/test control are useless!

         They are here since when testing against
         Yaci/public testnets they are needed.

    -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{64}) %n%msg%n
            </pattern>
        </encoder>
    </appender>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>integration-tests.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{64} %n%msg%n
            </pattern>
        </encoder>
    </appender>

    <appender name="MERMAID" class="ch.qos.logback.core.FileAppender">
        <file>stage4-peers-interaction.mmd</file>
        <append>false</append>
        <layout class="hydrozoa.integration.MermaidSequenceDiagramLayout">
            <pattern>%msg%n</pattern>
        </layout>
    </appender>
    <logger name="Mermaid.PeerLiaison" level="info" additivity="false">
        <appender-ref ref="MERMAID"/>
    </logger>

    <!-- common test loggers -->
    <!-- default: warn -->
    <logger name="org.scalacheck.commands.ModelBasedSuite" level="warn"/>
    <logger name="test.CardanoBackendMock" level="debug"/>
    <logger name="CardanoBackend" level="debug"/>

    <!-- stage1 loggers -->
    <!-- default: info -->
    <logger name="Stage1.Commands" level="info"/>
    <logger name="Stage1.CommandGenerators" level="info"/>
    <logger name="Stage1.ScenarioGenerators" level="info"/>
    <logger name="Stage1.Model" level="info"/>
    <logger name="Stage1.Sut" level="info"/>
    <logger name="Stage1.Suite" level="info"/>

    <!-- stage4 loggers -->
    <!-- default: info -->
    <logger name="Stage4.Commands" level="info"/>
    <logger name="Stage4.CommandGenerators" level="info"/>
    <logger name="Stage4.ScenarioGenerators" level="info"/>
    <logger name="Stage4.Model" level="info"/>
    <logger name="Stage4.Sut" level="info"/>
    <logger name="Stage4.Suite" level="info"/>
    <logger name="Stage4.BlockBriefObserver" level="info"/>


    <!-- hydrozoa -->
    <!-- default: warn -->
    <logger name="BlockWeaver" level="info"/>
    <logger name="StackComposer" level="debug"/>
    <logger name="FastConsensusActor" level="debug"/>
    <logger name="SlowConsensusActor" level="debug"/>
    <logger name="EventSequencer" level="info"/>
    <logger name="CardanoLiaison" level="debug"/>
    <logger name="JointLedger" level="info"/>
    <logger name="HeadMultisigRegimeManager" level="info"/>
    <logger name="CoilMultisigRegimeManager" level="info"/>
    <logger name="RuleBasedActor" level="debug"/>
    <logger name="Limiter" level="debug"/>
    <logger name="PeerLiaison" level="debug"/>
    <logger name="PeerLiaison.HeadToHead" level="debug"/>
    <logger name="PeerLiaison.HubToCoil" level="debug"/>
    <logger name="PeerLiaison.CoilToHub" level="debug"/>
    <logger name="PeerLiaisonMermaid" level="info"/>
    <logger name="PeerTransport" level="debug"/>
    <logger name="CoilPeerWsTransport" level="debug"/>
    <logger name="HubWsTransport" level="debug"/>
    <logger name="CoilAckSequencer" level="info"/>
    <logger name="HydrozoaHttp" level="info"/>
    <logger name="RemoteL2Ledger" level="info"/>
    <logger name="Persistence" level="info"/>
    <logger name="BlockHeader" level="info"/>
    <logger name="TxTiming" level="info"/>
    <logger name="DepositsMap" level="info"/>

    <!-- libs -->
    <!-- default: warn -->
    <logger name="scalus" level="warn"/>
</configuration>
