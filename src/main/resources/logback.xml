<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{64}) %n%msg%n
            </pattern>
        </encoder>
    </appender>
    <!-- Protocol trace: writes JSONL to file, no formatting overhead -->
    <appender name="TRACE_FILE" class="ch.qos.logback.core.FileAppender">
        <file>hydrozoa-trace.jsonl</file>
        <encoder><pattern>%msg%n</pattern></encoder>
    </appender>
    <appender name="LOG_FILE" class="ch.qos.logback.core.FileAppender">
        <file>hydrozoa.log</file>
        <encoder><pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{64}) %n%msg%n</pattern></encoder>
    </appender>
    <logger name="hydrozoa.trace" level="info" additivity="false">
        <appender-ref ref="TRACE_FILE"/>
    </logger>
    <root level="trace">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="LOG_FILE"/>
    </root>
    <logger name="CardanoBackend" level="warn"/>
    <logger name="CardanoLiaison" level="trace"/>
    <logger name="PeerLiaison" level="trace"/>
    <logger name="PeerLiaison.HeadToHead" level="trace"/>
    <logger name="PeerLiaison.HubToCoil" level="trace"/>
    <logger name="PeerLiaison.CoilToHub" level="trace"/>
    <logger name="JointLedger" level="trace"/>
    <logger name="HeadMultisigRegimeManager" level="trace"/>
    <logger name="DisputeActor" level="trace"/>
    <logger name="EvacuationActor" level="trace"/>
    <logger name="Limiter" level="trace"/>
    <logger name="RemoteL2Ledger" level="trace"/>
    <logger name="HydrozoaHttp" level="trace"/>
    <logger name="CoilPeerWsTransport" level="trace"/>
    <logger name="HubWsTransport" level="trace"/>
    <logger name="CoilAckSequencer" level="trace"/>
    <logger name="Persistence" level="info"/>
    <logger name="BlockHeader" level="info"/>
    <logger name="TxTiming" level="info"/>
    <logger name="DepositsMap" level="debug"/>
    <logger name="hydrozoa" level="trace"/>
    <logger name="scalus" level="trace"/>
</configuration>
